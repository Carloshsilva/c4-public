<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Selic Pre-Matching API v2.0" enabled="true">
      <stringProp name="TestPlan.comments">API Pre-Matching (Selic Conecta) v2.0. OAuth2 client_credentials. Troque ambiente via -q &lt;arquivo&gt;.properties e passe -Jclient_id / -Jclient_secret. Defaults = Sandbox.</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <stringProp name="TestPlan.user_define_classpath"></stringProp>
    </TestPlan>
    <hashTree>
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Variaveis (defaults = Sandbox)" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="base_url" elementType="Argument">
            <stringProp name="Argument.name">base_url</stringProp>
            <stringProp name="Argument.value">${__P(base_url,https://api.sandbox.selic.gov.br/pre-matching)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="token_url" elementType="Argument">
            <stringProp name="Argument.name">token_url</stringProp>
            <stringProp name="Argument.value">${__P(token_url,https://api.sandbox.selic.gov.br/auth/realms/logon/protocol/openid-connect/token)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="client_id" elementType="Argument">
            <stringProp name="Argument.name">client_id</stringProp>
            <stringProp name="Argument.value">${__P(client_id,)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="client_secret" elementType="Argument">
            <stringProp name="Argument.name">client_secret</stringProp>
            <stringProp name="Argument.value">${__P(client_secret,)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="dataMovimento" elementType="Argument">
            <stringProp name="Argument.name">dataMovimento</stringProp>
            <stringProp name="Argument.value">${__P(dataMovimento,2020-11-26)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="idNegocio" elementType="Argument">
            <stringProp name="Argument.name">idNegocio</stringProp>
            <stringProp name="Argument.value">${__P(idNegocio,202011260002457)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="idEspecificacao" elementType="Argument">
            <stringProp name="Argument.name">idEspecificacao</stringProp>
