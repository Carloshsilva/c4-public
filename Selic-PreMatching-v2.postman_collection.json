  "item": [
    {
      "name": "Autenticacao",
      "description": "Fluxo OAuth2 (Keycloak / realm `logon`). Preencha `client_id` e `client_secret` no Environment.",
      "item": [
        {
          "name": "Obter token (client_credentials)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "Accept",
                "value": "*/*"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}"
                }
              ]
            },
            "url": {
              "raw": "{{token_url}}",
              "host": [
                "{{token_url}}"
              ]
            },
            "description": "Recupera um token JWT via OAuth2 (grant_type=client_credentials).\n\nO token e salvo automaticamente na variavel `access_token` do Environment.\n\nObs.: a collection tambem renova o token sozinha em cada request (pre-request script), entao normalmente voce nao precisa rodar este request manualmente."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Salva o token retornado no Environment",
                  "let data;",
                  "try { data = pm.response.json(); } catch (e) { data = {}; }",
                  "if (data.access_token) {",
                  "  pm.environment.set(\"access_token\", data.access_token);",
                  "  const ttl = (data.expires_in ? data.expires_in : 300) * 1000;",
                  "  pm.environment.set(\"access_token_expiry\", String(Date.now() + ttl - 15000));",
                  "  pm.test(\"Token obtido\", function () { pm.expect(data.access_token).to.be.a(\"string\"); });",
                  "} else {",
                  "  pm.test(\"Token obtido\", function () { pm.expect.fail(\"Resposta sem access_token\"); });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
