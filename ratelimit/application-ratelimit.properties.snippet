# ======= Rate Limit (MESCLE estas linhas no seu application.properties) =======
# Reiniciar sem recompilar altera estes valores.
ratelimit.limite-documental=300
ratelimit.n=2
ratelimit.margem=0.9
# reserva de seguranca = 2 x C, C = threads paralelas de saida por instancia (voces: 10) => 20
ratelimit.reserva=20
